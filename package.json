{
  "name": "mabel-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "build": "tsup src",
    "dev": "tsx watch src/server.ts",
    "docker:build": "docker build -t mabel_backend docker",
    "docker:run": "docker run -it -v $(pwd)/.:/app mabel_backend bash",
    "compose:up": "docker compose --env-file ./.env -f docker/docker-compose.yml up -d --build",
    "compose:down": "docker compose -f docker/docker-compose.yml down",
    "compose:exec": "docker compose --env-file ./.env -f docker/docker-compose.yml exec -it backend bash"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "prisma": "^7.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
