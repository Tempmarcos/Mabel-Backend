generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Aluno {
  id             String    @id @default(uuid())
  nome           String
  dataNascimento DateTime
  ativo          Boolean   @default(true)
  dataCadastro   DateTime  @default(now())
  fichas         Ficha[]
  chamada        Chamada[]
  diarias        Diaria[]
  vinculos       Vinculo[]
  informacoes    String?
  medicamentos   String?
  religiao       String?

  @@index([ativo])
  @@map("alunos")
}

model Ficha {
  id                      String                @id @default(uuid())
  alunoId                 String
  aluno                   Aluno                 @relation(fields: [alunoId], references: [id])
  turmaId                 String
  turma                   Turma                 @relation(fields: [turmaId], references: [id])
  planoId                 String
  plano                   Plano                 @relation(fields: [planoId], references: [id])
  valor                   Float
  descontoPercentual      Float?
  descontoFixo            Float?
  diasDaSemana            DiaSemana[]
  responsavelFinanceiroId String
  responsavelFinanceiro   ResponsavelFinanceiro @relation(fields: [responsavelFinanceiroId], references: [id])

  rua         String
  numero      String
  bairro      String
  cidade      String
  estado      String
  cep         String
  complemento String?

  serie      String
  escola     String
  dataInicio DateTime  @default(now())
  dataFim    DateTime?

  @@index([alunoId])
  @@map("fichas")
}

model Chamada {
  alunoId  String
  aluno    Aluno    @relation(fields: [alunoId], references: [id])
  turno    Turno
  presenca Boolean
  data     DateTime @db.Date

  @@id([alunoId, data, turno], name: "chamada_pk")
  @@map("chamadas")
}

model Diaria {
  valor   Float
  alunoId String
  data    DateTime @db.Date
  turno   Turno

  aluno Aluno @relation(fields: [alunoId], references: [id])

  @@id([alunoId, data, turno], name: "diaria_pk")
  @@map("diarias")
}

enum Turno {
  MANHA
  TARDE
  NOITE
}

enum DiaSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

model Plano {
  id                String  @id @default(uuid())
  nome              String
  descricao         String?
  frequenciaSemanal Int
  valor             Float
  almoco            Boolean
  fichas            Ficha[]

  @@map("planos")
}

model Turma {
  id          String   @id @default(uuid())
  nome        String
  turno       Turno
  idadeMinima Float?
  idadeMaxima Float?
  capacidade  Int?
  professorId String
  professor   User     @relation(fields: [professorId], references: [id])
  createdAt   DateTime @default(now())
  fichas      Ficha[]

  @@map("turmas")
}

model Vinculo {
  alunoId           String
  aluno             Aluno       @relation(fields: [alunoId], references: [id])
  responsavelId     String
  responsavel       Responsavel @relation(fields: [responsavelId], references: [id])
  tipo              TipoVinculo
  buscaAutorizada   Boolean
  contatoEmergencia Boolean

  @@id([alunoId, responsavelId], name: "vinculo_pk")
  @@map("vinculos")
}

enum TipoVinculo {
  PAI
  MAE
  PARENTE
  CONHECIDO
  TRANSPORTE
}

model Responsavel {
  id               String                 @id @default(uuid())
  nome             String
  cpf              String                 @unique
  email            String?
  telefone         String?
  trabalho         String?
  funcao           String?
  vinculos         Vinculo[]
  dadosFinanceiros ResponsavelFinanceiro?

  @@map("responsaveis")
}

model ResponsavelFinanceiro {
  id              String      @id @default(uuid())
  responsavelId   String      @unique
  responsavel     Responsavel @relation(fields: [responsavelId], references: [id])
  fichas          Ficha[]
  rua             String
  numero          String
  bairro          String
  cidade          String
  estado          String
  cep             String
  complemento     String?
  metodoPagamento String

  @@map("responsaveis_financeiros")
}

model User {
  id             String    @id @default(uuid())
  admin          Boolean   @default(false)
  nome           String
  nomeDeUsuario  String?
  fotoUrl        String?
  email          String    @unique
  senhaHash      String
  permissoes     String[]
  tipo           String // ADMIN, COORDENADOR, PROFESSOR, etc.
  turmas         Turma[]
  ativo          Boolean   @default(true)
  created_at     DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  ultimoLogin    DateTime?
  vistoPorUltimo DateTime?
  tarefas        Tarefa[]  @relation(name: "responsavel")
  tarefasCriadas Tarefa[]  @relation(name: "criador")

  @@map("usuarios")
}

model Tarefa {
  id                String    @id @default(uuid())
  nome              String
  descricao         String?
  userResponsavelId String
  responsavel       User      @relation("responsavel", fields: [userResponsavelId], references: [id], onDelete: Cascade)
  userCriadorId     String
  criador           User      @relation("criador", fields: [userCriadorId], references: [id], onDelete: Cascade)
  tipo              String
  status            String
  dataAgendada      DateTime?
  dataExecutada     DateTime?

  @@index([userResponsavelId])
  @@index([userCriadorId])
  @@map("tarefas")
}

model LogEvento {
  id               String   @id @default(uuid())
  nomeEvento       String
  dataOcorrencia   DateTime
  aggregateId      String
  dados            Json
  moduloOrigem     String
  dataPersistencia DateTime @default(now())

  @@index([nomeEvento])
  @@index([aggregateId])
  @@index([dataOcorrencia])
  @@map("logs_eventos")
}
